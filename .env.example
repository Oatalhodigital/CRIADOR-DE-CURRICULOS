# Firebase Configuration (public - safe for client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=sua_chave_firebase_aqui
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# OpenAI Configuration (server-only - NEVER use NEXT_PUBLIC_ prefix)
OPENAI_API_KEY=sua_chave_openai_aqui

# Mercado Pago Configuration (server-only - NEVER use NEXT_PUBLIC_ prefix)
MERCADO_PAGO_ACCESS_TOKEN=seu_token_mercado_pago_aqui

# Admin Email (server-only)
ADMIN_EMAIL=seu_email_admin_aqui