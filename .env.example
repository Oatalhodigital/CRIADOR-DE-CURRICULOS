# Firebase Configuration (public - safe for client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=sua_chave_firebase_aqui
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# OpenAI Configuration (server-only - NEVER use NEXT_PUBLIC_ prefix)
OPENAI_API_KEY=sua_chave_openai_aqui

# Mercado Pago Configuration (server-only - NEVER use NEXT_PUBLIC_ prefix)
MERCADO_PAGO_ACCESS_TOKEN=seu_token_mercado_pago_aqui

# Firebase Admin SDK (server-only - needed for /api/leads, /api/resumes, /api/payment/webhook)
# Option A: paste the entire service account JSON in one line
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"seu-projeto-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@seu-projeto-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxx%40seu-projeto-id.iam.gserviceaccount.com"}
# Option B: separate values (recommended on Vercel to avoid JSON escaping issues)
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@seu-projeto-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin Email (server-only)
ADMIN_EMAIL=seu_email_admin_aqui
